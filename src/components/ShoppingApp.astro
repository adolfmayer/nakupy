---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { CatalogItem } from "../domain/types";
import { CATALOG_SEED } from "../data/catalog.seed";
import { getCatalogImageById } from "../assets/catalog/catalogImages";

const items = CATALOG_SEED satisfies readonly CatalogItem[];

type CatalogRenderItem = Readonly<{
  item: CatalogItem;
  image: ImageMetadata | undefined;
  thumb: {
    src: string;
    srcset: string;
    sizes: string;
  } | null;
}>;

const thumbSizes = "96px";
const renderItems: readonly CatalogRenderItem[] = await Promise.all(
  items.map(async (item) => {
    const image = getCatalogImageById(item.id);
    if (image == null) return { item, image: undefined, thumb: null };

    const thumb = await getImage({
      src: image,
      width: 96,
      height: 120,
      format: "webp",
      quality: 70,
    });

    return {
      item,
      image,
      thumb: {
        src: thumb.src,
        srcset: thumb.srcSet.attribute,
        sizes: thumbSizes,
      },
    };
  }),
);
---

<main class="mx-auto max-w-6xl px-4 py-6" data-shopping-app>
  <div class="grid items-start gap-4 grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)]">
    <section class="rounded-2xl bg-emerald-500/10 p-4 ring-1 ring-emerald-400/20">
      <div class="mb-3 text-xs font-semibold tracking-wide text-emerald-100/90">
        Catalog
      </div>

      <div class="rounded-xl bg-zinc-950 ring-1 ring-zinc-800">
        <input
          id="catalog-search"
          placeholder="Search…"
          class="h-11 w-full bg-transparent px-4 text-sm outline-none placeholder:text-zinc-500"
          aria-label="Search catalog"
        />
      </div>

      <div class="mt-4">
        <div
          id="catalog-grid"
          class="grid grid-cols-1 gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
        >
          {renderItems.map(({ item, image, thumb }, index) => {
            const alt = `Photo of ${item.title}`;
            const isLcpCandidate = index < 4;

            return (
              <button
                type="button"
                data-catalog-item
                data-item-id={item.id}
                data-item-title={item.title}
                data-item-tags={(item.tags ?? []).join(" ")}
                data-thumb-src={thumb?.src}
                data-thumb-srcset={thumb?.srcset}
                data-thumb-sizes={thumb?.sizes}
                class="group relative aspect-4/5 overflow-hidden rounded-2xl text-left ring-1 transition ring-orange-400/25 bg-orange-500/15 hover:bg-orange-500/20 select-none"
              >
                <div class="absolute inset-0">
                  {image != null ? (
                    <>
                      {isLcpCandidate ? (
                        <Image
                          src={image}
                          width={400}
                          height={500}
                          format="webp"
                          quality={75}
                          alt={alt}
                          loading="eager"
                          fetchpriority="high"
                          sizes="(min-width: 1024px) 240px, (min-width: 768px) 220px, (min-width: 640px) 260px, 100vw"
                          class="h-full w-full object-cover opacity-90 transition group-hover:opacity-100"
                        />
                      ) : (
                        <Image
                          src={image}
                          width={96}
                          height={120}
                          format="webp"
                          quality={70}
                          alt={alt}
                          loading="lazy"
                          sizes="96px"
                          class="h-full w-full object-cover opacity-90 transition group-hover:opacity-100"
                        />
                      )}
                      <div class="absolute inset-0 bg-linear-to-t from-zinc-950/70 via-zinc-950/15 to-transparent" />
                    </>
                  ) : (
                    <div class="absolute inset-0 bg-zinc-900/80" />
                  )}
                </div>

                <div class="absolute bottom-0 left-0 right-0 p-3">
                  <div class="text-sm font-semibold leading-tight">{item.title}</div>
                </div>
              </button>
            );
          })}
        </div>
      </div>
    </section>

    <aside class="sticky top-4 rounded-2xl bg-red-500/15 p-4 ring-1 ring-red-400/25">
      <div class="flex flex-wrap items-center justify-between gap-x-3 gap-y-2">
        <div class="text-sm font-semibold tracking-wide text-red-100">
          Shopping List
        </div>
        <div class="flex items-center gap-2 text-xs text-red-200/80">
          <span>
            <span id="list-count">0</span> items
          </span>
          <button
            id="clear-all"
            type="button"
            aria-label="Clear all items"
            class="relative inline-flex items-center justify-center rounded-full px-3 py-1.5 text-xs font-semibold ring-1 transition select-none cursor-not-allowed opacity-50 ring-red-400/20 bg-red-500/10 text-red-100/70"
            disabled
            aria-disabled="true"
          >
            Clear all
          </button>
        </div>
      </div>

      <div class="mt-3 rounded-xl bg-red-500/10 ring-1 ring-red-400/20 overflow-hidden">
        <div class="min-h-[420px] max-h-[calc(100dvh-8rem)] overflow-y-auto p-3">
          <div id="list-empty" class="grid h-[380px] place-items-center text-center">
            <div class="max-w-[28ch] text-sm text-red-100/80">
              Click items in the catalog to build your shopping list.
            </div>
          </div>

          <div id="list-grid" class="hidden grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3"></div>
        </div>
      </div>
    </aside>
  </div>

  <script>
    import "./shopping-app/client.ts";
  </script>
</main>

